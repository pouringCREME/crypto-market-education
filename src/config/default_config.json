    "data_source": "simulated",
    "update_frequency": "1m",
    "market_scenarios": {
      "bull_market": {
        "description": "Rising market scenario for learning trend following",
        "duration_hours": 24,
        "volatility_multiplier": 0.8,
        "trend_bias": 0.001
      },
      "bear_market": {
        "description": "Declining market scenario for learning risk management",
        "duration_hours": 24,
        "volatility_multiplier": 1.2,
        "trend_bias": -0.001
      },
      "sideways": {
        "description": "Range-bound market for learning patience and range trading",
        "duration_hours": 24,
        "volatility_multiplier": 1.0,
        "trend_bias": 0
      },
      "high_volatility": {
        "description": "Volatile market for stress testing strategies",
        "duration_hours": 12,
        "volatility_multiplier": 2.0,
        "trend_bias": 0
      }
    },
    "risk_limits": {
      "max_position_size": 0.1,
      "max_daily_loss": 0.05,
      "max_leverage": 1.0,
      "stop_loss_required": true
    },
    "educational_features": {
      "trade_explanations": true,
      "risk_warnings": true,
      "performance_analytics": true,
      "learning_reminders": true
    }
  },
  "analysis": {
